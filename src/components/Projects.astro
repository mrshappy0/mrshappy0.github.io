---
---

<section id="projects" class="section">
  <div class="section-marker"></div>
  <h2 class="section-head">Projects</h2>

  <div class="proj-list">

    <article class="proj-card">
      <div class="proj-top">
        <h3 class="proj-name">Mini Mealie</h3>
        <span class="proj-tag">Chrome + Firefox</span>
      </div>
      <p class="proj-desc">Open-source browser extension with <strong>2,000+</strong> active users and growing international adoption. Built with AI-assisted workflows and custom MCP tooling.</p>
      <span class="proj-tech">TypeScript · MCP</span>
    </article>

    <article class="proj-card">
      <div class="proj-top">
        <h3 class="proj-name">Home Lab Infrastructure</h3>
        <span class="proj-tag">Self-hosted</span>
      </div>
      <p class="proj-desc"><strong>30+ containers</strong> running local LLMs and AI agent frameworks behind zero-trust architecture with SSO, reverse proxy, and intrusion prevention.</p>
      <span class="proj-tech">Docker · Ollama · Mastra · Traefik · Cloudflare · CrowdSec</span>
    </article>

  </div>
</section>

<style>
  .section-marker {
    width: 12px;
    height: 12px;
    background: var(--color-text);
    opacity: 0.12;
    margin-bottom: 1.5rem;
  }

  .section-head {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
  }

  .proj-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .proj-card {
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }

  .proj-top {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .proj-name {
    font-size: 1rem;
    font-weight: 600;
  }

  .proj-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--color-text-muted);
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
  }

  .proj-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .proj-desc strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .proj-tech {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .proj-list {
      grid-template-columns: 1fr;
    }
  }
</style>
