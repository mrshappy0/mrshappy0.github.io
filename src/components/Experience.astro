---
---

<section id="work" class="section">
  <h2 class="section-head">Work</h2>

  <div class="work-list">

    <article class="work-item">
      <div class="work-meta">
        <span class="work-date">2021 &mdash; now</span>
        <span class="work-co">Cox Automotive</span>
      </div>
      <div class="work-body">
        <h3 class="work-role">Senior Software Engineer</h3>
        <div class="work-entry">
          <span class="entry-label">AI Agent for Enterprise CRM</span>
          <p class="entry-desc">Conversational AI agent for natural language CRM queries on one of the automotive industry's largest datasets. Function calling via AWS Strands Agents.</p>
          <span class="entry-tech">Python · AWS Strands Agents</span>
        </div>
        <div class="work-entry">
          <span class="entry-label">MCP Developer Platform</span>
          <p class="entry-desc">MCP tools for AI coding assistants to interact with Rally project management. Adopted across hundreds of internal engineering teams.</p>
          <span class="entry-tech">TypeScript · Bun · Node.js · Zod</span>
        </div>
        <div class="work-entry">
          <span class="entry-label">Direct Mail Automation</span>
          <p class="entry-desc">Led end-to-end development of direct mail API and React dashboard. Built CI/CD from inception, integrated Lob API.</p>
          <span class="entry-tech">TypeScript · AWS CDK · React · Next.js</span>
        </div>
      </div>
    </article>

    <article class="work-item">
      <div class="work-meta">
        <span class="work-date">2020 &mdash; 2021</span>
        <span class="work-co">Alpine Media</span>
      </div>
      <div class="work-body">
        <h3 class="work-role">React Native Developer</h3>
        <div class="work-entry">
          <span class="entry-label">Mobile App Platform</span>
          <p class="entry-desc">Maintained app generator and CMS-driven theming engine for branded iOS and Android apps at major ski resorts.</p>
          <span class="entry-tech">React Native</span>
        </div>
      </div>
    </article>

  </div>
</section>

<style>
  .section-head {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .work-item {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 2rem;
  }

  .work-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .work-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .work-co {
    font-size: 0.875rem;
    color: var(--color-text);
    font-weight: 600;
  }

  .work-role {
    font-size: 1.0625rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .work-entry {
    margin-bottom: 1.25rem;
    padding-left: 0.75rem;
    border-left: 1px solid var(--color-border);
  }

  .work-entry:last-child {
    margin-bottom: 0;
  }

  .entry-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .entry-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 0.3rem;
  }

  .entry-tech {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .work-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .work-meta {
      flex-direction: row;
      gap: 0.75rem;
      align-items: baseline;
    }
  }
</style>
