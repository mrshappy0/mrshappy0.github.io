---
---

<header class="site-header">
  <a href="/" class="logo" aria-label="Adam Shappy, Home">
    <img
      class="logo-desktop"
      src="/adam-mono-text.png"
      alt="Adam Shappy"
      width="100"
      height="104"
    />
    <img
      class="logo-mobile"
      src="/adam-monogram-mobile.png"
      alt="AS"
      width="50"
      height="52"
    />
  </a>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
  }

  .logo img {
    display: block;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .logo:hover img {
    opacity: 1;
  }

  .logo-desktop {
    display: block;
  }

  .logo-mobile {
    display: none;
  }

  @media (max-width: 640px) {
    .site-header {
      padding: 1rem 1.25rem;
    }

    .logo-desktop {
      display: none;
    }

    .logo-mobile {
      display: block;
    }
  }
</style>
