---
---

<section class="hero">
  <div class="hero-grid-bg"></div>
  <div class="hero-monogram">
    <img src="/adam-mono-text.png" alt="" class="hero-monogram-img" width="200" height="207" />
  </div>
  <div class="hero-text">
    <h1 class="hero-name">Adam Shappy</h1>
    <p class="hero-title">Senior Software Engineer</p>
    <p class="hero-line">I build AI agents, developer tooling,<br />and cloud-native platforms.</p>
    <div class="hero-cta-row">
      <a href="#contact" class="hero-cta">Get in touch</a>
      <a href="/Cresta_Adam_Shappy_Resume.pdf" class="hero-cta-secondary" target="_blank">Resume</a>
    </div>
  </div>
  <div class="hero-glitch hero-glitch-1"></div>
  <div class="hero-glitch hero-glitch-2"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    padding: 6rem 2rem 4rem;
    overflow: hidden;
  }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-grid) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .hero-monogram {
    flex-shrink: 0;
  }

  .hero-monogram-img {
    display: block;
    width: 180px;
    height: auto;
    opacity: 0.92;
  }

  .hero-text {
    max-width: 420px;
  }

  .hero-name {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }

  .hero-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.04em;
  }

  .hero-line {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .hero-cta-row {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-cta {
    display: inline-flex;
    padding: 0.6rem 1.4rem;
    background: var(--color-text);
    color: #fff;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
  }

  .hero-cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--glitch-red), var(--glitch-magenta), var(--glitch-blue), var(--glitch-yellow));
    opacity: 0;
    transition: opacity 0.4s;
    mix-blend-mode: screen;
  }

  .hero-cta:hover::after {
    opacity: 0.3;
  }

  .hero-cta-secondary {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-cta-secondary:hover {
    color: var(--color-text);
  }

  .hero-glitch {
    position: absolute;
    height: 1px;
    left: 0;
    right: 0;
  }

  .hero-glitch-1 {
    top: 38%;
    background: var(--glitch-magenta);
    opacity: 0.12;
    transform: translateX(-4px);
  }

  .hero-glitch-2 {
    top: 62%;
    background: var(--glitch-blue);
    opacity: 0.12;
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }

    .hero-monogram-img {
      width: 120px;
    }

    .hero-cta-row {
      justify-content: center;
    }

    .hero-text {
      max-width: 100%;
    }
  }
</style>
