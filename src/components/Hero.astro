<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-content">
    <p class="hero-greeting">Hello, I'm</p>
    <h1 class="hero-name">Adam Shappy</h1>
    <h2 class="hero-title">Senior Software Engineer</h2>
    <p class="hero-subtitle">
      I build AI agents, developer tooling, and cloud-native platforms
      that bridge ambitious ideas with real-world impact.
    </p>
    <div class="hero-links">
      <a href="#contact" class="hero-cta cmyk-border">Get in touch</a>
      <a href="/Cresta_Adam_Shappy_Resume.pdf" class="hero-link-secondary" target="_blank">Resume &rarr;</a>
    </div>
    <div class="hero-socials">
      <a href="https://github.com/mrshappy0" target="_blank" rel="noopener">github</a>
      <span class="social-dot">&middot;</span>
      <a href="https://linkedin.com/in/adam-shappy" target="_blank" rel="noopener">linkedin</a>
      <span class="social-dot">&middot;</span>
      <a href="https://medium.com/@adam_shappy" target="_blank" rel="noopener">medium</a>
      <span class="social-dot">&middot;</span>
      <a href="mailto:atom@shaplabs.net">email</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem 2rem 4rem;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
    background-size: 50px 50px;
    mask-image: radial-gradient(ellipse 70% 50% at 40% 40%, black 25%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 50% at 40% 40%, black 25%, transparent 70%);
  }

  .hero-content {
    position: relative;
    max-width: 680px;
    z-index: 1;
  }

  .hero-greeting {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    margin-bottom: 0.5rem;
    letter-spacing: 0.08em;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 400;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    max-width: 500px;
    margin-bottom: 2.25rem;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.5rem;
    background: var(--color-text);
    color: #fff;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    filter: saturate(0%);
    transition: filter 0.6s ease, transform 0.2s ease;
  }

  .hero-cta:hover {
    filter: saturate(100%);
    transform: translateY(-2px);
  }

  .hero-link-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1rem;
    color: var(--color-text);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .hero-link-secondary:hover {
    color: var(--cmyk-magenta);
  }

  .hero-socials {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }

  .hero-socials a {
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .hero-socials a:hover {
    color: var(--color-text);
  }

  .social-dot {
    opacity: 0.4;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 5rem 1.25rem 3rem;
    }

    .hero-grid {
      background-size: 36px 36px;
    }
  }
</style>
